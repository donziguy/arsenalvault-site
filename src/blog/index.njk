<header class="gradient-dark py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl lg:text-5xl font-display font-bold text-white mb-4">Arsenal Vault Blog</h1>
        <p class="text-gray-300 text-lg max-w-2xl mx-auto">Practical guides for firearms inventory management, insurance records, collection documentation, and smarter range prep.</p>
    </div>
</header>

<section class="py-10 bg-white border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-3 gap-6">
            <a href="/blog/insurance-documentation.html" class="rounded-xl border border-gray-200 p-6 hover:border-av-gold transition">
                <p class="text-xs uppercase tracking-wide text-av-gold font-bold mb-2">Most Useful First</p>
                <h2 class="font-display font-bold text-gray-900 mb-2">Insurance Documentation</h2>
                <p class="text-gray-600 text-sm">What to collect before an adjuster asks for proof.</p>
            </a>
            <a href="/blog/spreadsheets-vs-apps.html" class="rounded-xl border border-gray-200 p-6 hover:border-av-gold transition">
                <p class="text-xs uppercase tracking-wide text-av-gold font-bold mb-2">Still Using Sheets?</p>
                <h2 class="font-display font-bold text-gray-900 mb-2">Spreadsheet vs App</h2>
                <p class="text-gray-600 text-sm">When a spreadsheet works, and when it starts costing you time.</p>
            </a>
            <a href="/security.html" class="rounded-xl border border-av-gold/30 bg-av-gold/5 p-6 hover:border-av-gold transition">
                <p class="text-xs uppercase tracking-wide text-av-gold font-bold mb-2">Privacy First</p>
                <h2 class="font-display font-bold text-gray-900 mb-2">Security Overview</h2>
                <p class="text-gray-600 text-sm">How Cloud and Desktop protect sensitive inventory records.</p>
            </a>
        </div>
    </div>
</section>

<section class="py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {% for post in collections.posts | reverse %}
            <article class="bg-white rounded-2xl border border-gray-200 p-7 hover-lift shadow-sm">
                <div class="text-sm text-gray-500 mb-3">
                    <span><i class="bi bi-calendar3 mr-1"></i>{{ post.date | readableDate }}</span>
                    {% if post.data.readTime %}<span class="ml-3"><i class="bi bi-clock mr-1"></i>{{ post.data.readTime }}</span>{% endif %}
                </div>
                <h2 class="text-xl font-display font-bold text-gray-900 mb-3">
                    <a href="{{ post.url }}" class="hover:text-av-gold transition">{{ post.data.ogTitle or post.data.title }}</a>
                </h2>
                <p class="text-gray-600 mb-5">{{ post.data.description }}</p>
                <a href="{{ post.url }}" class="inline-flex items-center gap-2 text-av-gold font-semibold hover:underline">Read Article <i class="bi bi-arrow-right"></i></a>
            </article>
            {% endfor %}
        </div>
    </div>
</section>

<section class="py-16 gradient-dark">
    <div class="max-w-3xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-display font-bold text-white mb-4">Ready to turn the advice into records?</h2>
        <p class="text-gray-400 mb-8">Create a free Cloud account or use the Windows Desktop app if you want local-only storage.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="https://app.arsenalvault.com/register?utm_source=arsenalvault.com&utm_medium=blog_index_cta&utm_campaign=free_account" class="gradient-gold text-av-dark px-8 py-3 rounded-xl font-semibold hover:opacity-90 transition">Create Free Account</a>
            <a href="/download.html" class="border-2 border-av-gold text-av-gold px-8 py-3 rounded-xl font-semibold hover:bg-av-gold hover:text-av-dark transition">Download Desktop</a>
        </div>
    </div>
</section>
